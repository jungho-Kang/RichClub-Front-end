{
  "rewrites": [
    {
      "source": "/naver-news/:path*",
      "destination": "https://openapi.naver.com/v1/search/news.json?:path*"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://richclub.efforthye.dev/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
